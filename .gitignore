## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Rider
.idea/

# VS Code
.vscode/

# DotCover
*.dotCover

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper

# NCrunch
_NCrunch_*
.*crunch*.local.xml

# MSTest
TestResults/

# NUnit
*.VisualState.xml
TestResult.xml

# Build artifacts
*.dll
*.exe
*.pdb
*.cache
*.ilk

# ASP.NET Core
appsettings.Development.json
appsettings.*.local.json

# Publish output
publish/
*.publishproj

# NuGet
*.nupkg
*.snupkg
packages/
.nuget/
project.lock.json
project.fragment.lock.json
artifacts/

# Logs
*.log

# OS files
[Dd]esktop.ini
Thumbs.db

# Mac
.DS_Store

# Environment files
.env
.env.*

# Coverage
coverage/
*.coverage
*.coveragexml

# Entity Framework
*.mdf
*.ldf

# Azure
*.azurePubxml
*.publishsettings

# Docker
docker-compose.override.yml

# Generated files
Generated_Code/

# Backup files
*.bak
*.backup

# Others
*.tmp
*.temp
